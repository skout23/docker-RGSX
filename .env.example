# RGSX Docker Environment Configuration

# Volume Paths
# Path to your ROM collection (mount point for downloaded games)
NAS_ROMS=/path/to/your/roms

# Path to RGSX saves/settings (persistent app data)
RGSX_SAVES=/path/to/your/rgsx-data

# Web Server Configuration
WEB_PORT=8080
TZ=UTC

# 1fichier API Key (optional)
# Place your 1fichier premium API key in: ${RGSX_SAVES}/ports/rgsx/1fichierAPI.txt
# Or set it here to automatically create the file:
# ONEFICHIER_API_KEY=your-api-key-here